{
  "name": "layered-call-capture",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant layered call capture: Retell voice + Twilio SMS + Trigger.dev orchestration + Supabase + Cal.com",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:webhooks": "tsx watch src/webhooks/server.ts",
    "dev:trigger": "trigger dev",
    "deploy:trigger": "trigger deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "provision": "tsx scripts/provision-client.ts",
    "agent:push": "tsx scripts/create-retell-agent.ts",
    "number:connect": "tsx scripts/connect-twilio-number.ts",
    "report": "tsx scripts/generate-report.ts",
    "smoke": "tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.47.10",
    "@trigger.dev/sdk": "^4.0.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.16",
    "luxon": "^3.5.0",
    "openai": "^5.0.0",
    "retell-sdk": "^4.0.0",
    "twilio": "^5.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.5",
    "trigger.dev": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
