# ── Copy to .env and fill in. Secrets live ONLY here (and in Railway/Trigger.dev env UIs). ──

# Supabase (Project Settings → API). Service role key: server-side only, never ship to a browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (Console → Account Info)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Credentials for the elastic SIP trunk credential list (you invent these; used Twilio<->Retell only)
TWILIO_SIP_USERNAME=retell-trunk-user
TWILIO_SIP_PASSWORD=

# Retell (Dashboard → API Keys)
RETELL_API_KEY=

# OpenAI — used directly by extraction, SMS agent, digests (voice LLM is billed through Retell)
OPENAI_API_KEY=
# Cheap model for SMS turns + transcript extraction; smart model for digests/reports.
OPENAI_MODEL_CHEAP=gpt-4.1-mini
OPENAI_MODEL_SMART=gpt-4.1

# Trigger.dev (Project → API Keys). Use the dev key locally, prod key on Railway.
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# Cal.com (Settings → Developer → API Keys). Default key; a client row can override with its own.
CALCOM_API_KEY=

# Public HTTPS base URL of the webhook service (Railway URL in prod, ngrok/cloudflared URL in dev).
# No trailing slash. Twilio signature validation reconstructs URLs from this — must match exactly.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Shared secret embedded in Retell inbound-webhook / custom-function URLs (?token=...).
# Generate: openssl rand -hex 24  (or any long random string)
INTERNAL_WEBHOOK_TOKEN=

# Cal.com webhook signing secret (set when creating the Cal.com webhook; leave blank to skip check in dev)
CALCOM_WEBHOOK_SECRET=

# Your cell — receives system failure alerts and (for client zero) owner alerts. E.164: +1XXXXXXXXXX
MY_CELL=

# Webhook service port (local dev; Railway injects PORT)
PORT=8080
